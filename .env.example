# ── Supabase (Project Settings → API) ──────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...   # anon public key

# ⚠️ SOLO en el servidor. Nunca con prefijo NEXT_PUBLIC_. No la subas a git.
SUPABASE_SERVICE_ROLE_KEY=eyJ...        # service_role secret key

# ── Salesforce (integración de casos — opcional) ───────────────────
# Mismas credenciales que usas en mayoristas-tracker.
SF_USERNAME=tu_usuario@etb.com.co
SF_PASSWORD=tu_contraseña_sf
SF_TOKEN=tu_token_de_seguridad_sf
SF_DOMAIN=login
